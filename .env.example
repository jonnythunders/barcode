# ============ Supabase ============
# Get these from your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: only needed if using the Supabase CLI locally (for migrations/types gen)
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=

# ============ Anthropic (required) ============
# Used for: agent chat (Barry), sentiment analysis, report narrative generation
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ============ Cron / internal auth ============
# Random string used by Vercel Cron to authenticate to /api/cron/* routes
# Generate with: openssl rand -hex 32
CRON_SECRET=

# ============ TikTok Developer API ============
# Apply at: https://developers.tiktok.com
# Standard app: 1-2 wk approval. Commercial Content API: ~2 days.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_COMMERCIAL_API_KEY=

# ============ Meta / Instagram Business Discovery ============
# Apply at: https://developers.facebook.com
# Used for public follower counts on Business/Creator accounts.
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=

# ============ Reddit API ============
# Register at: https://reddit.com/prefs/apps (choose "script" type — instant approval)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=barcode-brand-intel/0.1.0
# Reddit also requires user credentials for script-type apps:
REDDIT_USERNAME=
REDDIT_PASSWORD=

# ============ SmartScout (from Barcode) ============
# Requires their Enterprise plan (~$399/mo). Their cost, not yours.
SMARTSCOUT_API_KEY=

# ============ Exploding Topics (from Barcode) ============
# Requires their Business plan ($249/mo). Their cost, not yours.
EXPLODING_TOPICS_API_KEY=

# ============ Resend (email delivery) ============
# https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL="Barcode Intel <onboarding@resend.dev>"

# ============ Optional: OpenAI (Whisper voice input — Adam carryover) ============
OPENAI_API_KEY=

# ============ App config ============
# Public base URL — used in email links etc.
NEXT_PUBLIC_APP_URL=http://localhost:3000
